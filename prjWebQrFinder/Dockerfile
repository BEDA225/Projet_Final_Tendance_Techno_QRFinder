# Dockerfile pour l'API Node.js - prjWebQrFinder

FROM node:20-alpine

WORKDIR /app

# Copier seulement les fichiers nťcessaires pour l'API
COPY package*.json ./
COPY server.js ./

# Installer les dťpendances
RUN npm install --production

# Exposer le port 3000
EXPOSE 3000

# Dťmarrer l'API
CMD ["node", "server.js"]